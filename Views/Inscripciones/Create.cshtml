@model practica2Web.Models.Inscripcion

@{
    ViewData["Title"] = "Nueva Inscripción";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card shadow border-0">
            <div class="card-header bg-gradient-dark text-white text-center py-4">
                <h4 class="mb-0">Inscripción de Estudiante</h4>
            </div>
            <div class="card-body p-4">

                <!-- 🔥 IMPORTANTE -->
                <form asp-action="Create" method="post">

                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <!-- ESTUDIANTE -->
                    <div class="mb-3">
                        <label class="form-label">Estudiante</label>
                        <select asp-for="EstudianteId" class="form-select">
                            <option value="">-- Seleccionar estudiante --</option>
                            @foreach (var e in ViewBag.EstudianteId)
                            {
                                <option value="@e.Value">@e.Text</option>
                            }
                        </select>
                        <span asp-validation-for="EstudianteId" class="text-danger"></span>
                    </div>

                    <!-- CURSO -->
                    <div class="mb-3">
                        <label class="form-label">Curso</label>
                        <select asp-for="CursoId" class="form-select">
                            <option value="">-- Seleccionar curso --</option>
                            @foreach (var c in ViewBag.CursoId)
                            {
                                <option value="@c.Value">@c.Text</option>
                            }
                        </select>
                        <span asp-validation-for="CursoId" class="text-danger"></span>
                    </div>

                    <!-- FECHA -->
                    <div class="mb-3">
                        <label asp-for="FechaInscripcion"></label>
                        <input asp-for="FechaInscripcion" class="form-control" type="date" />
                        <span asp-validation-for="FechaInscripcion" class="text-danger"></span>
                    </div>

                    <!-- ESTADO -->
                    <div class="mb-3">
                        <label asp-for="Estado"></label>
                        <select asp-for="Estado" class="form-select">
                            <option value="">-- Seleccionar --</option>
                            <option value="Activo">Activo</option>
                            <option value="Completado">Completado</option>
                            <option value="Pendiente">Pendiente</option>
                        </select>
                        <span asp-validation-for="Estado" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn btn-dark w-100">Guardar</button>

                </form>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}