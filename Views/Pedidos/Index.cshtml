@model IEnumerable<practica2Web.Models.Pedido>
@{
    ViewData["Title"] = "Todos los Pedidos";
}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h4 class="card-title mb-0"><i class="mdi mdi-cart mr-2 text-info"></i> Lista de Pedidos</h4>
                <a asp-action="Create" class="btn btn-info btn-rounded waves-effect">
                    <i class="mdi mdi-cart-plus"></i> Nuevo Pedido
                </a>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-striped table-bordered">
                        <thead>
                            <tr>
                                <th>Pedido #</th>
                                <th>Cliente</th>
                                <th>Fecha</th>
                                <th>Total</th>
                                <th class="text-center">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td><span class="badge badge-primary">ORD-@item.Id.ToString("D4")</span></td>
                                    <td>
                                        <a asp-controller="Clientes" asp-action="Details" asp-route-id="@item.ClienteId">@item.Cliente?.Nombre</a>
                                    </td>
                                    <td>@item.FechaPedido.ToShortDateString()</td>
                                    <td><strong class="text-success">$@item.Total.ToString("N2")</strong></td>
                                    <td class="text-center">
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm btn-rounded">
                                            <i class="mdi mdi-delete"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                            @if (!Model.Any())
                            {
                                <tr>
                                    <td colspan="5" class="text-center py-4 text-muted">
                                        <i class="mdi mdi-cart-off" style="font-size:32px;"></i><br>No hay pedidos registrados
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
