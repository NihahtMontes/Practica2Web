@model practica2Web.Models.Pedido

@{
    ViewData["Title"] = "Nuevo Pedido";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card shadow border-0">
            <div class="card-header bg-gradient-info text-white text-center py-4">
                <h4 class="mb-0">Crear Nuevo Pedido</h4>
            </div>
            <div class="card-body p-4">

                <!-- 🔥 IMPORTANTE -->
                <form asp-action="Create" method="post">

                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <!-- CLIENTE -->
                    <div class="mb-3">
                        <label class="form-label">Cliente</label>
                        <select asp-for="ClienteId" class="form-select">
                            <option value="">-- Seleccionar cliente --</option>
                            @foreach (var c in ViewBag.ClienteId)
                            {
                                <option value="@c.Value">@c.Text</option>
                            }
                        </select>
                        <span asp-validation-for="ClienteId" class="text-danger"></span>
                    </div>

                    <!-- FECHA -->
                    <div class="mb-3">
                        <label asp-for="FechaPedido"></label>
                        <input asp-for="FechaPedido" class="form-control" type="datetime-local" />
                        <span asp-validation-for="FechaPedido" class="text-danger"></span>
                    </div>

                    <!-- TOTAL -->
                    <div class="mb-3">
                        <label asp-for="Total"></label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input asp-for="Total" class="form-control" type="number" step="0.01" />
                        </div>
                        <span asp-validation-for="Total" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn btn-info w-100 text-white">
                        Guardar Pedido
                    </button>

                    <a asp-action="Index" asp-controller="Clientes" class="btn btn-link w-100 mt-2">
                        Cancelar
                    </a>

                </form>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}