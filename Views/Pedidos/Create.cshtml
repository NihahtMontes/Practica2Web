@model practica2Web.Models.Pedido

@{
    ViewData["Title"] = "Nuevo Pedido";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card shadow border-0">
            <div class="card-header bg-gradient-info text-white text-center py-4">
                <h4 class="mb-0"><i class="bi bi-cart-plus-fill"></i> Crear Nuevo Pedido</h4>
            </div>
            <div class="card-body p-4">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="ClienteId" class="form-label fw-semibold">Seleccione Cliente</label>
                        <select asp-for="ClienteId" class="form-select" asp-items="ViewBag.ClienteId"></select>
                    </div>

                    <div class="mb-3">
                        <label asp-for="FechaPedido" class="form-label fw-semibold"></label>
                        <input asp-for="FechaPedido" class="form-control" type="datetime-local" />
                        <span asp-validation-for="FechaPedido" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Total" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input asp-for="Total" class="form-control" type="number" step="0.01" value="150.00" />
                        </div>
                        <span asp-validation-for="Total" class="text-danger small"></span>
                        <div class="form-text text-muted small">El total se calcula automáticamente o puede ajustarse manualmente</div>
                    </div>

                    <div class="d-grid gap-2 mt-4">
                        <button type="submit" class="btn btn-info text-white btn-lg"><i class="bi bi-save"></i> Guardar Pedido</button>
                        <a asp-action="Index" asp-controller="Clientes" class="btn btn-link text-muted">Cancelar y Volver</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-gradient-info {
        background: linear-gradient(135deg, #36b9cc 0%, #1a8a9a 100%);
    }
</style>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
