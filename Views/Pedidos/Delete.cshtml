@model practica2Web.Models.Pedido
@{
    ViewData["Title"] = "Eliminar Pedido";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card text-center">
            <div class="card-body p-5">
                <i class="mdi mdi-alert-circle-outline text-danger" style="font-size:80px;"></i>
                <h3 class="font-weight-bold mt-3">¿Eliminar este pedido?</h3>
                <p class="text-muted mb-1">Pedido: <strong class="badge badge-primary">ORD-@Model.Id.ToString("D4")</strong></p>
                <p class="text-muted mb-1">Cliente: <strong>@Model.Cliente?.Nombre</strong></p>
                <p class="text-muted mb-4">Total: <strong class="text-success">$@Model.Total.ToString("N2")</strong></p>
                <form asp-action="Delete">
                    <input type="hidden" asp-for="Id" />
                    <button type="submit" class="btn btn-danger btn-rounded btn-lg mr-2">
                        <i class="mdi mdi-delete"></i> Sí, Eliminar
                    </button>
                    <a asp-controller="Clientes" asp-action="Details" asp-route-id="@Model.ClienteId"
                       class="btn btn-light btn-rounded btn-lg">
                        <i class="mdi mdi-arrow-left"></i> Cancelar
                    </a>
                </form>
            </div>
        </div>
    </div>
</div>
