@model practica2Web.Models.Curso

@{
    ViewData["Title"] = "Detalles del Curso";
}

<div class="container mt-4 text-dark">
    <div class="row">
        <div class="col-lg-4">
            <div class="card shadow border-0 mb-4 h-100">
                <div class="card-header bg-dark text-white py-4 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="bi bi-journal-text"></i> Datos del Curso</h5>
                </div>
                <div class="card-body">
                    <h4 class="fw-bold">@Model.Nombre</h4>
                    <p class="text-muted"><span class="badge bg-primary">@Model.Creditos Creditos</span></p>
                    <hr>
                    <div class="d-grid gap-2">
                         <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-dark">
                            <i class="bi bi-pencil"></i> Editar Curso
                        </a>
                        <a asp-action="Index" class="btn btn-link text-muted">Atrás a la lista</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card shadow border-0">
                 <div class="card-header bg-light py-3">
                    <h5 class="mb-0 text-secondary fw-bold"><i class="bi bi-mortarboard"></i> Alumnos Inscritos</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead>
                                <tr class="table-light">
                                    <th class="ps-4">Estudiante</th>
                                    <th>Fecha Inscripción</th>
                                    <th>Estado</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var insc in Model.Inscripciones)
                                {
                                    <tr>
                                        <td class="ps-4 fw-bold">@insc.Estudiante.Nombre</td>
                                        <td>@insc.FechaInscripcion.ToShortDateString()</td>
                                        <td>
                                            <span class="badge @(insc.Estado == "Activo" ? "bg-success" : "bg-warning")">@insc.Estado</span>
                                        </td>
                                    </tr>
                                }
                                @if (!Model.Inscripciones.Any())
                                {
                                    <tr>
                                        <td colspan="3" class="text-center py-5 text-muted">No hay alumnos inscritos en este curso</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
