@model practica2Web.Models.Curso

@{
    ViewData["Title"] = "Editar Curso";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card shadow border-0">
            <div class="card-header bg-dark text-white text-center py-4">
                <h4 class="mb-0"><i class="bi bi-pencil-square"></i> Modificar Curso</h4>
            </div>
            <div class="card-body p-4">
                <form asp-action="Edit">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <input type="hidden" asp-for="Id" />

                    <div class="mb-3">
                        <label asp-for="Nombre" class="form-label fw-semibold"></label>
                        <input asp-for="Nombre" class="form-control" />
                        <span asp-validation-for="Nombre" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Creditos" class="form-label fw-semibold">Créditos</label>
                        <input asp-for="Creditos" class="form-control" type="number" min="1" max="10" />
                        <span asp-validation-for="Creditos" class="text-danger small"></span>
                    </div>

                    <div class="d-grid gap-2 mt-4">
                        <button type="submit" class="btn btn-dark btn-lg"><i class="bi bi-save"></i> Guardar Cambios</button>
                        <a asp-action="Index" class="btn btn-link text-muted">Atrás a la lista</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
