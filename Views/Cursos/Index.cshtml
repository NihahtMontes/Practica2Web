@model IEnumerable<practica2Web.Models.Curso>
@{
    ViewData["Title"] = "Cursos";
}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h4 class="card-title mb-0">
                    <i class="mdi mdi-book-open-page-variant mr-2" style="color:#1e88e5;"></i> Catálogo de Cursos
                </h4>
                <a asp-action="Create" class="btn btn-info btn-rounded waves-effect waves-light">
                    <i class="mdi mdi-plus-circle"></i> Nuevo Curso
                </a>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-striped table-bordered">
                        <thead>
                            <tr>
                                <th style="width:50px;">#</th>
                                <th>Nombre del Curso</th>
                                <th style="width:120px; text-align:center;">Créditos</th>
                                <th class="text-center" style="width:200px;">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="text-primary font-weight-bold">@item.Id</td>
                                    <td><strong>@item.Nombre</strong></td>
                                    <td class="text-center">
                                        <span class="badge badge-info badge-pill"
                                              style="font-size:13px; padding:6px 14px;">
                                            @item.Creditos
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        <a asp-action="Details" asp-route-id="@item.Id"
                                           class="btn btn-info btn-sm btn-rounded waves-effect" title="Ver Alumnos">
                                            <i class="mdi mdi-account-multiple"></i> Alumnos
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.Id"
                                           class="btn btn-warning btn-sm btn-rounded waves-effect" title="Editar">
                                            <i class="mdi mdi-pencil"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.Id"
                                           class="btn btn-danger btn-sm btn-rounded waves-effect" title="Eliminar">
                                            <i class="mdi mdi-delete"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                            @if (!Model.Any())
                            {
                                <tr>
                                    <td colspan="4" class="text-center py-4 text-muted">
                                        <i class="mdi mdi-book-open-outline" style="font-size:32px; display:block; margin-bottom:8px;"></i>
                                        No hay cursos registrados
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
