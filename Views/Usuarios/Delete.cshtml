@model practica2Web.Models.Usuario
@{
    ViewData["Title"] = "Eliminar Usuario";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card">
            <div class="card-body text-center p-5">
                <div class="mb-4" style="color:#ef5350; font-size: 80px;">
                    <i class="mdi mdi-alert-circle-outline"></i>
                </div>
                <h3 class="card-title font-weight-bold">¿Eliminar usuario?</h3>
                <p class="text-muted mb-1">Estás a punto de eliminar permanentemente:</p>
                <h5 class="text-danger font-weight-bold mb-1">@Model.Nombre</h5>
                <p class="text-muted small mb-4">@Model.Email — Se eliminará también su perfil asociado.</p>
                <form asp-action="Delete">
                    <input type="hidden" asp-for="Id" />
                    <button type="submit" class="btn btn-danger btn-rounded btn-lg waves-effect waves-light mr-2">
                        <i class="mdi mdi-delete"></i> Sí, Eliminar
                    </button>
                    <a asp-action="Index" class="btn btn-light btn-rounded btn-lg waves-effect">
                        <i class="mdi mdi-arrow-left"></i> Cancelar
                    </a>
                </form>
            </div>
        </div>
    </div>
</div>
