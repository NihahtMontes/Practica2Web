@model practica2Web.Models.Usuario

@{
    ViewData["Title"] = "Eliminar Usuario";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6 col-lg-4">
        <div class="card shadow border-0 text-center">
            <div class="card-body p-5">
                <div class="mb-4 text-danger">
                    <i class="bi bi-exclamation-triangle-fill display-1"></i>
                </div>
                <h4 class="card-title fw-bold">¿Estás seguro?</h4>
                <p class="text-muted mb-4">Se eliminará permanentemente al usuario <strong>@Model.Nombre</strong> y su perfil asociado.</p>
                
                <form asp-action="Delete">
                    <input type="hidden" asp-for="Id" />
                    <div class="d-grid gap-2 mb-3">
                        <button type="submit" class="btn btn-danger btn-lg"><i class="bi bi-trash-fill"></i> SÍ, ELIMINAR</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">No, volver</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
