@model IEnumerable<practica2Web.Models.Usuario>
@{
    ViewData["Title"] = "Usuarios";
}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h4 class="card-title mb-0"><i class="mdi mdi-account-multiple text-info mr-2"></i> Lista de Usuarios</h4>
                <a asp-action="Create" class="btn btn-info btn-rounded waves-effect waves-light">
                    <i class="mdi mdi-account-plus"></i> Nuevo Usuario
                </a>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-striped table-bordered">
                        <thead class="thead-dark">
                            <tr>
                                <th>#</th>
                                <th>Nombre</th>
                                <th>Email</th>
                                <th>Dirección</th>
                                <th>Teléfono</th>
                                <th>Nacimiento</th>
                                <th class="text-center">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.Id</td>
                                    <td><strong>@item.Nombre</strong></td>
                                    <td>@item.Email</td>
                                    <td>@item.Perfil?.Direccion</td>
                                    <td>@item.Perfil?.Telefono</td>
                                    <td>@item.Perfil?.FechaNacimiento.ToShortDateString()</td>
                                    <td class="text-center">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm btn-rounded waves-effect" title="Editar">
                                            <i class="mdi mdi-pencil"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm btn-rounded waves-effect" title="Eliminar">
                                            <i class="mdi mdi-delete"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                            @if (!Model.Any())
                            {
                                <tr>
                                    <td colspan="7" class="text-center py-4 text-muted">
                                        <i class="mdi mdi-information-outline font-24"></i><br>No hay usuarios registrados
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
