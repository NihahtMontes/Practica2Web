@model practica2Web.ViewModels.UsuarioPerfilViewModel
@{
    ViewData["Title"] = "Nuevo Usuario";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header bg-info text-white">
                <h4 class="card-title mb-0 text-white"><i class="mdi mdi-account-plus mr-2"></i> Crear Nuevo Usuario + Perfil</h4>
                <small class="text-white-50">Relación 1:1 — El perfil se crea junto con el usuario</small>
            </div>
            <div class="card-body">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                    
                    <h5 class="text-info mb-3"><i class="mdi mdi-account"></i> Datos del Usuario</h5>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Nombre" class="control-label font-weight-bold">Nombre</label>
                                <input asp-for="Nombre" class="form-control" placeholder="Nombre completo" />
                                <span asp-validation-for="Nombre" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Email" class="control-label font-weight-bold">Email</label>
                                <input asp-for="Email" class="form-control" type="email" placeholder="correo@ejemplo.com" />
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>

                    <hr class="mt-2 mb-3">
                    <h5 class="text-info mb-3"><i class="mdi mdi-card-account-details"></i> Datos del Perfil</h5>

                    <div class="form-group">
                        <label asp-for="Direccion" class="control-label font-weight-bold"></label>
                        <input asp-for="Direccion" class="form-control" placeholder="Dirección completa" />
                        <span asp-validation-for="Direccion" class="text-danger small"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Telefono" class="control-label font-weight-bold"></label>
                                <input asp-for="Telefono" class="form-control" placeholder="809-000-0000" />
                                <span asp-validation-for="Telefono" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="FechaNacimiento" class="control-label font-weight-bold"></label>
                                <input asp-for="FechaNacimiento" class="form-control" type="date" />
                                <span asp-validation-for="FechaNacimiento" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>

                    <div class="mt-3">
                        <button type="submit" class="btn btn-info btn-rounded waves-effect waves-light">
                            <i class="mdi mdi-content-save"></i> Guardar
                        </button>
                        <a asp-action="Index" class="btn btn-light btn-rounded ml-2">
                            <i class="mdi mdi-arrow-left"></i> Cancelar
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
