<!DOCTYPE html>
<html dir="ltr" lang="es">
<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="Proyecto 2 - CRUD con Relaciones Avanzadas EF Core">
    <title>@ViewData["Title"] - Proyecto 2</title>

    <!-- Bootstrap 4 CDN -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css">
    <!-- Material Design Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@mdi/font@@7.4.47/css/materialdesignicons.min.css">
    <!-- Nice-Admin style (custom) -->
    <link rel="stylesheet" href="~/css/nice-admin.css" asp-append-version="true">
</head>

<body>
    <!-- Preloader -->
    <div class="preloader" id="preloader">
        <div style="text-align:center">
            <div class="spinner-border text-primary" role="status" style="width:3rem;height:3rem;">
                <span class="sr-only">Cargando...</span>
            </div>
        </div>
    </div>

    <div id="main-wrapper" data-sidebartype="full">
        <!-- ========== TOPBAR ========== -->
        <header class="topbar">
            <nav class="navbar top-navbar navbar-expand-md navbar-dark">
                <div class="navbar-header">
                    <!-- Mobile toggle -->
                    <a class="nav-toggler d-block d-md-none" href="javascript:void(0)" id="mobile-sidebar-toggle">
                        <i class="mdi mdi-menu"></i>
                    </a>
                    <!-- Logo -->
                    <div class="navbar-brand">
                        <a asp-controller="Home" asp-action="Index" class="logo">
                            <b class="logo-icon">P2</b>
                            <span class="logo-text">Proyecto 2</span>
                        </a>
                        <a class="sidebartoggler d-none d-md-inline-flex" href="javascript:void(0)" id="sidebar-toggle" title="Colapsar menú">
                            <i class="mdi mdi-menu" style="color:rgba(255,255,255,.8); font-size:22px; line-height:1;"></i>
                        </a>
                    </div>
                    <!-- Mobile right toggle -->
                    <a class="topbartoggler d-block d-md-none" href="javascript:void(0)"
                       data-toggle="collapse" data-target="#navbarTop">
                        <i class="mdi mdi-dots-vertical" style="color:#fff; font-size:22px;"></i>
                    </a>
                </div>

                <div class="navbar-collapse collapse" id="navbarTop">
                    <ul class="navbar-nav float-left mr-auto">
                        <li class="nav-item">
                            <span class="nav-link d-none d-md-flex" style="color:rgba(255,255,255,.7); font-size:13px;">
                                <i class="mdi mdi-view-dashboard mr-1"></i> Sistema CRUD — EF Core Relaciones
                            </span>
                        </li>
                    </ul>
                    <ul class="navbar-nav float-right">
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-toggle="dropdown"
                               style="color:#fff; display:flex; align-items:center; gap:6px;">
                                <i class="mdi mdi-account-circle" style="font-size:26px;"></i>
                                <span class="d-none d-sm-inline">Admin</span>
                            </a>
                            <div class="dropdown-menu dropdown-menu-right" style="border:none; box-shadow:0 5px 25px rgba(0,0,0,.12); border-radius:10px; min-width:200px;">
                                <div class="d-flex align-items-center p-3" style="background:#1e88e5; border-radius:10px 10px 0 0;">
                                    <i class="mdi mdi-account-circle" style="font-size:40px; color:#fff;"></i>
                                    <div class="ml-2">
                                        <div style="color:#fff; font-weight:700; font-size:14px;">Administrador</div>
                                        <small style="color:rgba(255,255,255,.75);">admin@proyecto2.com</small>
                                    </div>
                                </div>
                                <div class="dropdown-divider m-0"></div>
                                <a class="dropdown-item py-2" href="#"><i class="mdi mdi-cog mr-2 text-muted"></i> Configuración</a>
                                <a class="dropdown-item py-2" href="#"><i class="mdi mdi-logout mr-2 text-muted"></i> Salir</a>
                            </div>
                        </li>
                    </ul>
                </div>
            </nav>
        </header>

        <!-- ========== LEFT SIDEBAR ========== -->
        <aside class="left-sidebar" id="left-sidebar">
            <div class="scroll-sidebar">
                <nav class="sidebar-nav">
                    <ul id="sidebarnav">
                        <li class="nav-small-cap">
                            <i class="mdi mdi-dots-horizontal"></i>
                            <span class="hide-menu">INICIO</span>
                        </li>
                        <li class="sidebar-item">
                            <a class="sidebar-link" asp-controller="Home" asp-action="Index">
                                <i class="mdi mdi-home"></i>
                                <span class="hide-menu">Dashboard</span>
                            </a>
                        </li>

                        <li class="nav-small-cap mt-2">
                            <i class="mdi mdi-dots-horizontal"></i>
                            <span class="hide-menu">RELACIÓN 1:1</span>
                        </li>
                        <li class="sidebar-item">
                            <a class="sidebar-link" asp-controller="Usuarios" asp-action="Index">
                                <i class="mdi mdi-account-multiple"></i>
                                <span class="hide-menu">Usuarios / Perfil</span>
                            </a>
                        </li>

                        <li class="nav-small-cap mt-2">
                            <i class="mdi mdi-dots-horizontal"></i>
                            <span class="hide-menu">RELACIÓN 1:N</span>
                        </li>
                        <li class="sidebar-item">
                            <a class="sidebar-link" asp-controller="Clientes" asp-action="Index">
                                <i class="mdi mdi-account-card-details"></i>
                                <span class="hide-menu">Clientes</span>
                            </a>
                        </li>
                        <li class="sidebar-item">
                            <a class="sidebar-link" asp-controller="Pedidos" asp-action="Index">
                                <i class="mdi mdi-cart"></i>
                                <span class="hide-menu">Pedidos</span>
                            </a>
                        </li>

                        <li class="nav-small-cap mt-2">
                            <i class="mdi mdi-dots-horizontal"></i>
                            <span class="hide-menu">RELACIÓN N:M</span>
                        </li>
                        <li class="sidebar-item">
                            <a class="sidebar-link" asp-controller="Estudiantes" asp-action="Index">
                                <i class="mdi mdi-school"></i>
                                <span class="hide-menu">Estudiantes</span>
                            </a>
                        </li>
                        <li class="sidebar-item">
                            <a class="sidebar-link" asp-controller="Cursos" asp-action="Index">
                                <i class="mdi mdi-book-open-page-variant"></i>
                                <span class="hide-menu">Cursos</span>
                            </a>
                        </li>
                    </ul>
                </nav>
            </div>
        </aside>

        <!-- ========== PAGE WRAPPER ========== -->
        <div class="page-wrapper">
            <!-- Breadcrumb -->
            <div class="page-breadcrumb">
                <div class="row">
                    <div class="col-5 align-self-center">
                        <h4 class="page-title">@ViewData["Title"]</h4>
                    </div>
                    <div class="col-7 align-self-center">
                        <div class="d-flex align-items-center justify-content-end">
                            <nav aria-label="breadcrumb">
                                <ol class="breadcrumb">
                                    <li class="breadcrumb-item">
                                        <a asp-controller="Home" asp-action="Index">Inicio</a>
                                    </li>
                                    <li class="breadcrumb-item active">@ViewData["Title"]</li>
                                </ol>
                            </nav>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Page Content -->
            <div class="container-fluid">
                @RenderBody()
            </div>

            <footer class="footer">
                Proyecto 2 &copy; @DateTime.Now.Year — CRUD con Relaciones Avanzadas · Entity Framework Core
            </footer>
        </div>

    </div><!-- end #main-wrapper -->

    <!-- Scripts via CDN -->
    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/popper.js@1.16.1/dist/umd/popper.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.min.js"></script>

    <script>
        // Hide preloader
        document.addEventListener('DOMContentLoaded', function () {
            setTimeout(function () {
                document.getElementById('preloader').style.display = 'none';
            }, 300);
        });

        // Sidebar toggle
        document.getElementById('sidebar-toggle')?.addEventListener('click', function () {
            var wrapper = document.getElementById('main-wrapper');
            if (wrapper.getAttribute('data-sidebartype') === 'full') {
                wrapper.setAttribute('data-sidebartype', 'mini-sidebar');
            } else {
                wrapper.setAttribute('data-sidebartype', 'full');
            }
        });

        // Mobile sidebar
        document.getElementById('mobile-sidebar-toggle')?.addEventListener('click', function () {
            document.getElementById('left-sidebar').classList.toggle('shown');
        });

        // Active link highlighting
        var currentPath = window.location.pathname.toLowerCase();
        document.querySelectorAll('.sidebar-link').forEach(function (link) {
            var href = link.getAttribute('href');
            if (href && currentPath.includes(href.split('/')[1]?.toLowerCase())) {
                link.parentElement.classList.add('active');
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
