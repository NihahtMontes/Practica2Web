@model IEnumerable<practica2Web.Models.Estudiante>
@{
    ViewData["Title"] = "Estudiantes";
}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h4 class="card-title mb-0">
                    <i class="mdi mdi-school mr-2" style="color:#7460ee;"></i> Lista de Estudiantes
                </h4>
                <a asp-action="Create" class="btn btn-rounded waves-effect waves-light"
                   style="background:#7460ee; color:#fff;">
                    <i class="mdi mdi-account-plus"></i> Nuevo Estudiante
                </a>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-striped table-bordered">
                        <thead>
                            <tr>
                                <th style="width:50px;">#</th>
                                <th>Nombre</th>
                                <th>Carrera</th>
                                <th class="text-center" style="width:180px;">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="text-primary font-weight-bold">@item.Id</td>
                                    <td><strong>@item.Nombre</strong></td>
                                    <td>@item.Carrera</td>
                                    <td class="text-center">
                                        <a asp-action="Details" asp-route-id="@item.Id"
                                           class="btn btn-sm btn-rounded waves-effect"
                                           style="background:#7460ee; color:#fff;" title="Ver Cursos">
                                            <i class="mdi mdi-book-open-variant"></i> Cursos
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.Id"
                                           class="btn btn-warning btn-sm btn-rounded waves-effect" title="Editar">
                                            <i class="mdi mdi-pencil"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.Id"
                                           class="btn btn-danger btn-sm btn-rounded waves-effect" title="Eliminar">
                                            <i class="mdi mdi-delete"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                            @if (!Model.Any())
                            {
                                <tr>
                                    <td colspan="4" class="text-center py-4 text-muted">
                                        <i class="mdi mdi-school" style="font-size:32px; display:block; margin-bottom:8px;"></i>
                                        No hay estudiantes registrados
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
