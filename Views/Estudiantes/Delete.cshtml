@model practica2Web.Models.Estudiante

@{
    ViewData["Title"] = "Eliminar Estudiante";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6 col-lg-4">
        <div class="card shadow border-0 text-center">
            <div class="card-body p-5">
                <div class="mb-4 text-danger">
                    <i class="bi bi-person-x-fill display-1"></i>
                </div>
                <h4 class="card-title fw-bold">¿Eliminar Estudiante?</h4>
                <p class="text-muted mb-4">¿Deseas eliminar permanentemente a <strong>@Model.Nombre</strong>? Se perderán todas sus calificaciones e inscripciones vinculadas.</p>
                
                <form asp-action="Delete">
                    <input type="hidden" asp-for="Id" />
                    <div class="d-grid gap-2 mb-3">
                        <button type="submit" class="btn btn-danger btn-lg"><i class="bi bi-person-dash"></i> CONFIRMAR BAJA</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
