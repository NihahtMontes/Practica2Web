@{
    ViewData["Title"] = "Inicio";
}

<div class="row">
    <!-- Hero card -->
    <div class="col-12 mb-4">
        <div class="card bg-primary text-white" style="background: linear-gradient(135deg, #1e88e5 0%, #1565c0 100%) !important;">
            <div class="card-body p-4">
                <div class="row align-items-center">
                    <div class="col-md-8">
                        <h1 class="display-5 font-weight-bold text-white mb-2">Proyecto 2: CRUD con Relaciones EF Core</h1>
                        <p class="lead text-white-50 mb-0">Implementación de relaciones avanzadas — Uno a Uno, Uno a Muchos y Muchos a Muchos con Entity Framework Core.</p>
                    </div>
                    <div class="col-md-4 text-right d-none d-md-block">
                        <i class="mdi mdi-database-search" style="font-size: 90px; opacity: 0.3;"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Relación 1:1 -->
    <div class="col-md-4 mb-4">
        <div class="card" style="border-top: 4px solid #1e88e5;">
            <div class="card-body">
                <div class="d-flex align-items-center mb-3">
                    <div class="btn btn-info btn-circle btn-lg mr-3">
                        <i class="mdi mdi-account-check font-24"></i>
                    </div>
                    <div>
                        <h5 class="card-title mb-0 font-weight-bold">Relación 1 : 1</h5>
                        <small class="text-muted">Usuario – Perfil</small>
                    </div>
                </div>
                <p class="text-muted">Relación obligatoria con carga mediante <code>.Include()</code> y formulario combinado que gestiona ambas entidades simultáneamente.</p>
                <a asp-controller="Usuarios" asp-action="Index" class="btn btn-info btn-rounded">
                    <i class="mdi mdi-account-multiple"></i> Ver Usuarios
                </a>
            </div>
        </div>
    </div>

    <!-- Relación 1:N -->
    <div class="col-md-4 mb-4">
        <div class="card" style="border-top: 4px solid #26c6da;">
            <div class="card-body">
                <div class="d-flex align-items-center mb-3">
                    <div class="btn btn-cyan btn-circle btn-lg mr-3" style="background:#26c6da; color:#fff;">
                        <i class="mdi mdi-cart font-24"></i>
                    </div>
                    <div>
                        <h5 class="card-title mb-0 font-weight-bold">Relación 1 : N</h5>
                        <small class="text-muted">Cliente – Pedido</small>
                    </div>
                </div>
                <p class="text-muted">Total calculado automáticamente, historial completo de pedidos por cliente con navegación fluida entre entidades.</p>
                <a asp-controller="Clientes" asp-action="Index" class="btn btn-rounded" style="background:#26c6da; color:#fff;">
                    <i class="mdi mdi-account-card-details"></i> Ver Clientes
                </a>
            </div>
        </div>
    </div>

    <!-- Relación N:M -->
    <div class="col-md-4 mb-4">
        <div class="card" style="border-top: 4px solid #7460ee;">
            <div class="card-body">
                <div class="d-flex align-items-center mb-3">
                    <div class="btn btn-circle btn-lg mr-3" style="background:#7460ee; color:#fff;">
                        <i class="mdi mdi-school font-24"></i>
                    </div>
                    <div>
                        <h5 class="card-title mb-0 font-weight-bold">Relación N : M</h5>
                        <small class="text-muted">Estudiante – Curso</small>
                    </div>
                </div>
                <p class="text-muted">Tabla intermedia <code>Inscripcion</code> con metadatos personalizados: <strong>FechaInscripción</strong> y <strong>Estado</strong>.</p>
                <a asp-controller="Estudiantes" asp-action="Index" class="btn btn-rounded" style="background:#7460ee; color:#fff;">
                    <i class="mdi mdi-school"></i> Ver Estudiantes
                </a>
            </div>
        </div>
    </div>

    <!-- Flujo del sistema -->
    <div class="col-12">
        <div class="card">
            <div class="card-header bg-light">
                <h5 class="card-title mb-0 font-weight-bold"><i class="mdi mdi-sitemap"></i> Flujo del Sistema</h5>
            </div>
            <div class="card-body">
                <div class="row text-center">
                    <div class="col">
                        <a asp-controller="Usuarios" asp-action="Index" class="btn btn-info btn-rounded waves-effect waves-light"><i class="mdi mdi-account-multiple mr-1"></i> Usuarios</a>
                        <div class="text-muted small mt-1">Perfil (1:1)</div>
                    </div>
                    <div class="col align-self-center text-muted"><i class="mdi mdi-arrow-right font-24"></i></div>
                    <div class="col">
                        <a asp-controller="Clientes" asp-action="Index" class="btn btn-rounded waves-effect" style="background:#26c6da; color:#fff;"><i class="mdi mdi-account-card-details mr-1"></i> Clientes</a>
                        <div class="text-muted small mt-1">Pedidos (1:N)</div>
                    </div>
                    <div class="col align-self-center text-muted"><i class="mdi mdi-arrow-right font-24"></i></div>
                    <div class="col">
                        <a asp-controller="Estudiantes" asp-action="Index" class="btn btn-rounded waves-effect" style="background:#7460ee; color:#fff;"><i class="mdi mdi-school mr-1"></i> Estudiantes</a>
                        <div class="text-muted small mt-1">Cursos (N:M)</div>
                    </div>
                    <div class="col align-self-center text-muted"><i class="mdi mdi-arrow-right font-24"></i></div>
                    <div class="col">
                        <a asp-controller="Cursos" asp-action="Index" class="btn btn-rounded waves-effect" style="background:#7460ee; color:#fff;"><i class="mdi mdi-book-open-page-variant mr-1"></i> Cursos</a>
                        <div class="text-muted small mt-1">Tabla N:M</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
