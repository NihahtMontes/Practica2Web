@model practica2Web.Models.Cliente

@{
    ViewData["Title"] = "Historial de Pedidos";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-lg-4 mb-4">
            <div class="card shadow border-0 h-100">
                <div class="card-header bg-primary text-white py-3">
                    <h5 class="mb-0"><i class="bi bi-person-circle"></i> Perfil del Cliente</h5>
                </div>
                <div class="card-body">
                    <h4 class="fw-bold mb-3">@Model.Nombre</h4>
                    <p class="mb-1 text-muted"><i class="bi bi-envelope"></i> @Model.Email</p>
                    <hr>
                    <div class="d-grid gap-2">
                        <a asp-controller="Pedidos" asp-action="Create" asp-route-clienteId="@Model.Id" class="btn btn-success">
                            <i class="bi bi-plus-circle"></i> Nuevo Pedido
                        </a>
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-info">
                            <i class="bi bi-pencil-square"></i> Editar Cliente
                        </a>
                        <a asp-action="Index" class="btn btn-link text-muted">Atrás a la lista</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card shadow border-0">
                <div class="card-header bg-light py-3">
                    <h5 class="mb-0 text-secondary"><i class="bi bi-receipt"></i> Historial de Pedidos</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead>
                                <tr class="table-light">
                                    <th class="ps-4">Pedido #</th>
                                    <th>Fecha</th>
                                    <th>Total</th>
                                    <th class="text-end pe-4">Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var pedido in Model.Pedidos.OrderByDescending(p => p.FechaPedido))
                                {
                                    <tr>
                                        <td class="ps-4 fw-bold text-primary">ORD-@pedido.Id.ToString("D4")</td>
                                        <td>@pedido.FechaPedido.ToShortDateString()</td>
                                        <td>$@pedido.Total.ToString("N2")</td>
                                        <td class="text-end pe-4">
                                            <a asp-controller="Pedidos" asp-action="Delete" asp-route-id="@pedido.Id" class="btn btn-link text-danger p-0" title="Eliminar Pedido">
                                                <i class="bi bi-trash"></i>
                                            </td>
                                        </tr>
                                    }
                                    @if (!Model.Pedidos.Any())
                                    {
                                        <tr>
                                            <td colspan="4" class="text-center py-5 text-muted">Este cliente no tiene pedidos registrados</td>
                                        </tr>
                                    }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
